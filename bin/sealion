#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local source dir
  source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*) ;;
      *) source="$dir/$source" ;;
    esac
  done
  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

SEALION_HOME="${SEALION_HOME:-$(cd "$(resolve_script_dir)/.." >/dev/null 2>&1 && pwd)}"
SEALION_VERSION="${SEALION_VERSION:-0.1.0-dev}"

print_help() {
  cat <<'HELP'
Sealion

global actions:
  sealion help
    show this help
  sealion version
    print the installed version
  sealion upgrade
    upgrade the installed CLI from GitHub when a newer commit is available
  sealion format [path...]
    format .skin and .scale files

features:
  install the CLI from GitHub
  # curl -fsSL <github-install-url> | bash
  curl -fsSL https://raw.githubusercontent.com/ryangerardwilson/sealion/main/install.sh | bash

  create a new project directory
  # sealion new <project-name>
  sealion new demo

  initialize the current empty directory
  # sealion init
  mkdir demo && cd demo && sealion init

  run the local development stack
  # sealion run dev
  cd demo && sealion run dev

  format view and component templates
  # sealion format
  sealion format
HELP
}

fail() {
  printf 'sealion: %s\n' "$*" >&2
  exit 1
}

require_template() {
  local template="$SEALION_HOME/templates/default"
  [ -d "$template" ] || fail "missing template: $template"
  printf '%s\n' "$template"
}

project_slug() {
  local input="$1"
  printf '%s' "$input" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9' '-' \
    | sed -e 's/^-*//' -e 's/-*$//' -e 's/--*/-/g'
}

escape_sed_replacement() {
  printf '%s' "$1" | sed -e 's/[\/&]/\\&/g'
}

copy_template() {
  local target="$1"
  local name="$2"
  local slug="$3"
  local template name_escaped slug_escaped

  template="$(require_template)"
  mkdir -p "$target"
  cp -R "$template/." "$target/"

  name_escaped="$(escape_sed_replacement "$name")"
  slug_escaped="$(escape_sed_replacement "$slug")"

  while IFS= read -r -d '' file; do
    sed -i.bak \
      -e "s/__PROJECT_NAME__/$name_escaped/g" \
      -e "s/__PROJECT_SLUG__/$slug_escaped/g" \
      "$file"
    rm -f "$file.bak"
  done < <(find "$target" -type f -print0)
}

ensure_project_name() {
  local name="$1"
  case "$name" in
    ""|.*|*/*) fail "project name must be a simple directory name" ;;
  esac
  case "$name" in
    *[!A-Za-z0-9._-]*) fail "project name may contain only letters, numbers, dots, underscores, and dashes" ;;
  esac
}

command_new() {
  local name="${1:-}"
  local target slug
  [ -n "$name" ] || fail "usage: sealion new <project-name>"
  ensure_project_name "$name"
  target="$PWD/$name"
  [ ! -e "$target" ] || fail "$name already exists"
  slug="$(project_slug "$name")"
  [ -n "$slug" ] || slug="sealion-app"
  copy_template "$target" "$name" "$slug"
  printf 'created %s\n' "$target"
  printf 'next:\n'
  printf '  cd %s\n' "$name"
  printf '  sealion run dev\n'
}

command_init() {
  local name slug existing
  existing="$(find "$PWD" -mindepth 1 -maxdepth 1 -print -quit)"
  [ -z "$existing" ] || fail "sealion init requires an empty directory"
  name="$(basename "$PWD")"
  ensure_project_name "$name"
  slug="$(project_slug "$name")"
  [ -n "$slug" ] || slug="sealion-app"
  copy_template "$PWD" "$name" "$slug"
  printf 'initialized %s\n' "$PWD"
  printf 'next:\n'
  printf '  sealion run dev\n'
}

compose_command() {
  if docker compose version >/dev/null 2>&1; then
    printf 'docker compose'
    return
  fi
  if command -v docker-compose >/dev/null 2>&1; then
    printf 'docker-compose'
    return
  fi
  fail "Docker Compose is required for sealion run dev"
}

compose_supports_watch() {
  local compose="$1"
  # shellcheck disable=SC2086
  $compose up --help 2>/dev/null | grep -q -- '--watch'
}

command_upgrade() {
  local current_head remote_head new_head install_script tmp_script

  if [ -d "$SEALION_HOME/.git" ]; then
    command -v git >/dev/null 2>&1 || fail "git is required to upgrade this installation"

    if [ -n "$(git -C "$SEALION_HOME" status --porcelain)" ]; then
      fail "cannot upgrade because $SEALION_HOME has local changes"
    fi

    current_head="$(git -C "$SEALION_HOME" rev-parse --short HEAD)"
    git -C "$SEALION_HOME" fetch --quiet origin main
    remote_head="$(git -C "$SEALION_HOME" rev-parse --short origin/main)"

    if [ "$current_head" = "$remote_head" ]; then
      printf 'sealion is already up to date (%s)\n' "$current_head"
      return
    fi

    git -C "$SEALION_HOME" pull --ff-only --quiet origin main
    new_head="$(git -C "$SEALION_HOME" rev-parse --short HEAD)"
    printf 'upgraded sealion %s -> %s\n' "$current_head" "$new_head"
    return
  fi

  install_script="$SEALION_HOME/install.sh"
  [ -f "$install_script" ] || fail "cannot find install.sh for this Sealion installation"
  tmp_script="$(mktemp)"
  cp "$install_script" "$tmp_script"
  SEALION_HOME="$SEALION_HOME" bash "$tmp_script"
  rm -f "$tmp_script"
}

command_format() {
  command -v python3 >/dev/null 2>&1 || fail "python3 is required for sealion format"
  if [ "$#" -eq 0 ]; then
    [ -f "$PWD/sealion.toml" ] || fail "run this inside a Sealion project or pass paths to sealion format"
    local paths=()
    [ -e view ] && paths+=("view")
    [ -e ui_components ] && paths+=("ui_components")
    if [ "${#paths[@]}" -eq 0 ]; then
      printf 'formatted 0 file(s)\n'
      return
    fi
    set -- "${paths[@]}"
  fi

  python3 - "$@" <<'PY'
from pathlib import Path
import re
import sys

TAG_RE = re.compile(r"<s-([A-Za-z0-9_.-]+)([^<>]*?:passover\s*=\s*\[.*?\][^<>]*?)(/?)>", re.S)
PASSOVER_RE = re.compile(r":passover\s*=\s*\[(.*?)\]", re.S)
NAME_RE = re.compile(r"[A-Za-z_][A-Za-z0-9_-]*")


def line_indent(text, pos):
    line_start = text.rfind("\n", 0, pos) + 1
    prefix = text[line_start:pos]
    return prefix if prefix.strip() == "" else ""


def format_tag(match, text):
    name = match.group(1)
    body = match.group(2).strip()
    self_closing = match.group(3) == "/" or body.endswith("/")
    if body.endswith("/"):
        body = body[:-1].rstrip()

    passover = PASSOVER_RE.search(body)
    if not passover:
        return match.group(0)

    names = NAME_RE.findall(passover.group(1))
    if not names:
        return match.group(0)

    before = body[:passover.start()].strip()
    after = body[passover.end():].strip()
    attrs = " ".join(part for part in (before, after) if part)

    indent = line_indent(text, match.start())
    item_indent = indent + "  "
    first = f"<s-{name}"
    if attrs:
        first += f" {attrs}"
    first += " :passover=["

    lines = [first]
    for index, item in enumerate(names):
        comma = "," if index < len(names) - 1 else ""
        lines.append(f"{item_indent}{item}{comma}")
    lines.append(f"{indent}] />" if self_closing else f"{indent}]>")
    return "\n".join(lines)


def format_text(text):
    out = []
    cursor = 0
    for match in TAG_RE.finditer(text):
        out.append(text[cursor:match.start()])
        out.append(format_tag(match, text))
        cursor = match.end()
    out.append(text[cursor:])
    formatted = "".join(out)
    if formatted and not formatted.endswith("\n"):
        formatted += "\n"
    return formatted


def iter_files(paths):
    seen = set()
    for raw in paths:
        root = Path(raw)
        if not root.exists():
            raise FileNotFoundError(raw)
        candidates = root.rglob("*") if root.is_dir() else [root]
        for path in candidates:
            if path.is_file() and path.suffix in {".skin", ".scale"}:
                resolved = path.resolve()
                if resolved not in seen:
                    seen.add(resolved)
                    yield path


changed = 0
try:
    for path in iter_files(sys.argv[1:]):
        original = path.read_text()
        formatted = format_text(original)
        if formatted != original:
            path.write_text(formatted)
            changed += 1
except FileNotFoundError as exc:
    print(f"sealion: path not found: {exc}", file=sys.stderr)
    sys.exit(1)

print(f"formatted {changed} file(s)")
PY
}

port_is_available() {
  local port="$1"
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$port" <<'PY'
import socket
import sys

port = int(sys.argv[1])
sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
try:
    sock.bind(("0.0.0.0", port))
except OSError:
    sys.exit(1)
finally:
    sock.close()
PY
    return
  fi

  if command -v ss >/dev/null 2>&1; then
    ! ss -ltn | awk '{print $4}' | grep -Eq "[:.]${port}$"
    return
  fi

  return 0
}

validate_port() {
  local port="$1"
  case "$port" in
    ""|*[!0-9]*) fail "SEALION_HTTP_PORT must be a number from 1 to 65535" ;;
  esac
  if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
    fail "SEALION_HTTP_PORT must be a number from 1 to 65535"
  fi
}

choose_dev_port() {
  local candidate

  if [ -n "${SEALION_HTTP_PORT:-}" ]; then
    validate_port "$SEALION_HTTP_PORT"
    if ! port_is_available "$SEALION_HTTP_PORT"; then
      fail "port $SEALION_HTTP_PORT is already in use; choose another with SEALION_HTTP_PORT=<port> sealion run dev"
    fi
    printf '%s\n' "$SEALION_HTTP_PORT"
    return
  fi

  for candidate in 8080 8081 8082 8083 8084 8085 18080 18081 18082 18083 18084 18085; do
    if port_is_available "$candidate"; then
      printf '%s\n' "$candidate"
      return
    fi
  done

  fail "no free dev port found; run with SEALION_HTTP_PORT=<port> sealion run dev"
}

command_run_dev() {
  [ -f "$PWD/sealion.toml" ] || fail "run this inside a Sealion project"
  local compose port requested_port
  compose="$(compose_command)"
  requested_port="${SEALION_HTTP_PORT:-}"
  port="$(choose_dev_port)"
  export SEALION_HTTP_PORT="$port"
  printf 'starting Sealion dev stack\n'
  if [ -z "$requested_port" ] && [ "$port" != "8080" ]; then
    printf 'port 8080 is busy; using %s\n' "$port"
  fi
  printf 'frontend: http://localhost:%s\n' "$port"
  printf 'backend API: http://localhost:%s/api\n' "$port"
  printf 'demo login: admin@sealion.local / password\n'
  if compose_supports_watch "$compose"; then
    printf 'watch: enabled for frontend and backend source rebuilds\n'
    # shellcheck disable=SC2086
    $compose up --build --watch
  else
    printf 'watch: unavailable in this Docker Compose; running without file watch\n'
    # shellcheck disable=SC2086
    $compose up --build
  fi
}

case "${1:-help}" in
  help|-h|--help)
    print_help
    ;;
  version)
    printf 'sealion %s\n' "$SEALION_VERSION"
    ;;
  upgrade)
    shift
    [ "$#" -eq 0 ] || fail "usage: sealion upgrade"
    command_upgrade
    ;;
  format)
    shift
    command_format "$@"
    ;;
  new)
    shift
    command_new "${1:-}"
    ;;
  init)
    shift
    [ "$#" -eq 0 ] || fail "usage: sealion init"
    command_init
    ;;
  run)
    shift
    case "${1:-}" in
      dev)
        shift
        [ "$#" -eq 0 ] || fail "usage: sealion run dev"
        command_run_dev
        ;;
      *) fail "usage: sealion run dev" ;;
    esac
    ;;
  *)
    fail "unknown command: $1"
    ;;
esac
