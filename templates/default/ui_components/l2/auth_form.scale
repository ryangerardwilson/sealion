<s-l1.heading :text="auth_title" />

{!! error !!}

<form method="post" action="{{ auth_action }}">
  <s-l1.form-label text="Email" />
  <s-l1.text-input name="email" type="email" :value="email_value" autocomplete="email" />

  <s-l1.form-label text="Password" />
  <s-l1.text-input name="password" type="password" value="" :autocomplete="password_autocomplete" />

  <s-l1.button type="submit" :label="submit_label" />
</form>

