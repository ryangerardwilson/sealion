{
  "name": "carbide-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run tailwind:build && bun --hot src/server.jsx",
    "build": "bun run tailwind:build && bun build --target=bun --production --outdir=build/server src/server.jsx",
    "start": "NODE_ENV=production bun src/server.jsx",
    "tailwind:build": "tailwindcss -i ./src/styles.css -o ./src/tailwind.css --minify"
  },
  "dependencies": {
    "@tailwindcss/cli": "4.3.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {}
}
